# Wallet used by Hardhat to deploy the SBT contract.
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Backend attester key. Keep private. The matching address is stored in the contract at deploy.
ATTESTER_PRIVATE_KEY=0xYOUR_ATTESTER_PRIVATE_KEY

# Wallet receiving mint payments.
TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET

# RPCs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# baseSepolia for tests, base for mainnet.
NEXT_PUBLIC_CHAIN=baseSepolia

# Fill after deploy.
NEXT_PUBLIC_SCORE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
